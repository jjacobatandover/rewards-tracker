# ── Required for "Update Benefits" feature ────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Required for auto-updates (Vercel KV + daily cron) ────────────────────────
# 1. Go to your Vercel project → Storage → Create KV Database
# 2. Connect to this project — Vercel will add these env vars automatically.
# 3. For local dev: run `vercel env pull .env.local` to get them.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ── Set by Vercel automatically for cron authentication ───────────────────────
# You don't need to set this manually — Vercel generates it for cron jobs.
# CRON_SECRET=...
